<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">API Keys</h1>
</div>

<% if flash[:api_key_token] %>
  <div class="mb-6 bg-green-50 border border-green-200 rounded-lg p-4">
    <p class="text-sm font-medium text-green-800 mb-2">Your new API key — copy it now, it won't be shown again:</p>
    <code class="block bg-white border border-green-200 rounded px-3 py-2 text-sm text-gray-900 select-all break-all"><%= flash[:api_key_token] %></code>
  </div>
<% end %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h2 class="text-lg font-medium text-gray-900 mb-4">Create API Key</h2>
  <%= form_with model: [ :admin, @api_key ], class: "flex flex-col md:flex-row gap-4 md:items-end" do |f| %>
    <div class="flex-1">
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, required: true, placeholder: "e.g. Airtable sync", class: "w-full border-gray-300 rounded-md shadow-sm" %>
    </div>
    <div class="flex-1">
      <%= f.label :admin_id, "Acts as", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :admin_id, @admins, :id, :full_name, { selected: current_admin.id }, class: "w-full border-gray-300 rounded-md shadow-sm" %>
      <p class="text-xs text-gray-500 mt-1">API requests with this key will have the same permissions as this admin.</p>
    </div>
    <div>
      <%= f.submit "Create Key", class: "bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acts As</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created By</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Used</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @api_keys.each do |api_key| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900"><%= api_key.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= api_key.admin.full_name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= api_key.created_by.full_name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <% if api_key.last_used_at %>
                <%= time_ago_in_words(api_key.last_used_at) %> ago
              <% else %>
                Never
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if api_key.revoked? %>
                <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">Revoked</span>
              <% else %>
                <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">Active</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
              <% unless api_key.revoked? %>
                <%= button_to "Revoke", admin_api_key_path(api_key), method: :delete,
                    data: { turbo_confirm: "Revoke #{api_key.name}? Requests using this key will stop working immediately." },
                    class: "text-red-600 hover:text-red-900" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @api_keys.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500">No API keys yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
