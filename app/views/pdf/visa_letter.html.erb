<div class="page">
  <%# Header %>
  <div class="header">
    <div class="header-left">
      <img src="<%= @default_logo_data_uri %>" alt="The Hack Foundation" style="max-width: 2.7in; max-height: 1.05in;">
    </div>
    <div class="header-right">
      <div class="header-right-name">The Hack Foundation</div>
      <div style="font-size: 9pt; font-style: italic;">D.B.A Hack Club</div>
      <div>8605 Santa Monica Boulevard #86294</div>
      <div>West Hollywood, CA 90069</div>
      <div><a href="mailto:team@hackclub.com">team@hackclub.com</a></div>
      <div>EIN: 81-2908499</div>
    </div>
  </div>

  <%# Date %>
  <div class="date-line">
    <%= Date.current.strftime("%B %d, %Y") %>
  </div>

  <%# Letter Body (rendered from template) %>
  <div class="letter-body">
    <%= simple_format(@rendered_body) %>
  </div>

  <%# Signature Block %>
  <div class="signature-block">
    <% if @signature_data_uri.present? %>
      <img src="<%= @signature_data_uri %>" alt="Signature" class="signature-image">
    <% elsif @default_signature_data_uri.present? %>
      <img src="<%= @default_signature_data_uri %>" alt="Signature" class="signature-image">
    <% end %>
    <div class="signature-name"><%= @template.signatory_name %></div>
    <div class="signature-title"><%= @template.signatory_title %></div>
  </div>

  <%# Footer %>
  <div class="letter-footer">
    <div class="security-pattern">
      AUTHENTIC DOCUMENT • <%= @participant.full_name.upcase %> • DOB: <%= @participant.date_of_birth.strftime("%Y-%m-%d") %> • AUTHENTIC DOCUMENT • <%= @participant.full_name.upcase %> • DOB: <%= @participant.date_of_birth.strftime("%Y-%m-%d") %> • AUTHENTIC DOCUMENT • <%= @participant.full_name.upcase %> • DOB: <%= @participant.date_of_birth.strftime("%Y-%m-%d") %> •
    </div>
    <div class="nonprofit-info">
      Hack Club is a 501(c)(3) public charity. Our nonprofit EIN is 81-2908499.
    </div>
    <div class="verification">
      Verify this letter at hack.club/visa-verify | Code: <span class="verification-code"><%= @application.verification_code %></span>
    </div>
  </div>
</div>
